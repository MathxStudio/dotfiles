.cache/zsh_calc_state

# --- Desktop Environment (KDE/Wayland) Junk ---
.Xauthority
.ICEauthority
.wget-hsts
.node_repl_history

# --- macOS / Cross-platform Junk (In case you sync to iPad/Mac) ---
.DS_Store
.AppleDouble
.LSOverride
