# --- Neovim / LazyVim ---
.config/nvim/.git
.config/nvim/lazy-lock.json
.config/nvim/orbit.json
**/*.swp
**/*.swo
**/.netrwhist
.config/nvim/undo/**
.config/nvim/backups/**
.config/nvim/sessions/**

# --- Zsh & Shell Noise ---
.zsh_history
.zhistory
.zcompdump*
.python_history
.lesshst

# --- System & Cache ---
.cache/**
.dbus/**
.gvfs/**
.local/share/Trash/**
.local/share/nvim/lazy/**
.local/share/nvim/mason/**

# --- Custom Scripts ---
