alias gco="git checkout"
alias gb='git branch'
alias gba='git branch -a'
alias gadd='git add'
alias ga='git add -p'
alias gcoall='git checkout -- .'
alias gr='git remote'
alias gre='git reset'

# ls alternative
alias l="eza -l --icons --git -a"
alias lt="eza --tree --level=3 --long --icons --git"
