eval "$(zoxide init zsh)"
export PATH="$HOME/.local/bin:$PATH"

unsetopt correct_all
unsetopt correct

# lightweight terminal calculator
fpath=(~/.config/zsh/functions $fpath)
autoload -Uz calc_core
